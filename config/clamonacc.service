[Unit]
Description=ClamAV On-Access Scanner
Requires=clamav-daemon.service
After=clamav-daemon.service

[Service]
Type=simple
ExecStartPre=/bin/sh -c 'i=0; while [ "$i" -lt 30 ]; do if [ -S /run/clamav/clamd.ctl ] || [ -S /var/run/clamav/clamd.ctl ]; then exit 0; fi; i=$((i + 1)); sleep 1; done; echo "clamd socket not ready" >&2; exit 1'
ExecStart=/usr/sbin/clamonacc --foreground --fdpass --log=/var/log/clamav/clamonacc.log
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
